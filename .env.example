# API Keys - Get free keys from:
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
# NewsAPI: https://newsapi.org/register

ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
NEWS_API_KEY=your_news_api_key_here

# Optional: For enhanced features
POLYGON_API_KEY=your_polygon_key_here
FINNHUB_API_KEY=your_finnhub_key_here

# =====================================================
# AI TRADING AGENT CONFIGURATION
# =====================================================

# Alpaca API (Paper Trading) - Get keys from:
# https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Claude API (Anthropic) - Get key from:
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =====================================================
# SUPABASE (Log storage + frontend auth)
# Get these from: supabase.com → Project Settings → API
# =====================================================

# Project URL (public, safe to use in frontend too)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service role key — PRIVATE, only used server-side by the agent
# Never put this in the frontend or commit it
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anon/public key — safe for the frontend (RLS protects the data)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...